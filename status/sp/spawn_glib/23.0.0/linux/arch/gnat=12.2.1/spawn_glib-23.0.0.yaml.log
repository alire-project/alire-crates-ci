Properties:
   Author: AdaCore
   Configuration: no modifiers
   Description: A simple library to spawn processes and communicate with them.
   GPR Scenario: OS := unix | osx | Windows_NT
   case OS is
      when Linux => GPR External: OS := unix
      when Macos => GPR External: OS := osx
      when Windows => GPR External: OS := Windows_NT
   License: Apache-2.0
   Long_Description: This is Glib integrated implementation of a spawn processes interface.
   Maintainer: Vadim Godunko <vgodunko@gmail.com>
   Maintainer: Max Reznik <reznikmm@gmail.com>
